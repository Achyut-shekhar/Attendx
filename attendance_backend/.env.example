# Database connection string (Neon, RDS, etc.)
DB_URL=postgresql://user:password@host/database?sslmode=require

# JWT secret — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET

# CORS — your frontend URL (for production)
FRONTEND_URL=http://localhost:5173

# Email Queue (optional, for Lambda/SQS)
EMAIL_QUEUE_URL=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Admin key for password resets
RESET_ADMIN_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET

# Faculty Registration Key — only faculty need a key to register (students register freely)
FACULTY_REGISTER_KEY=CHANGE_THIS
